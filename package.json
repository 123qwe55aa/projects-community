    "better-sqlite3": "^11.10.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.44.7",
    "nanoid": "^5.1.11",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
